}

fn variantTerms() -> () {
  variant{V left = l}
  variant{
    V left = l
  }

  let v: V = variant{V left = l}
  let v: V = variant{
    V left = l
  }

  v <- variant{V left = l}
  v <- variant{
    P left = l
  }

  ()
}

