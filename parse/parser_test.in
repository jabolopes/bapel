  p2 <- set p {x = 0}
  p2 <- set p {x = 0, y = 1}
  p2 <- set p {
    x = 0,
  }
  p2 <- set p {
    x = 0,
    y = 1,
  }

  let p2: P = set struct{a = 0, b = 1} {
    x = 0,
    y = 1,
  }

  ()
}

fn structTerms() -> () {
  struct{}
  struct{a = 0}
  struct{a = 0, b = 1}
  struct{
    a = 0,
