module test.traits

pub trait Size {
  fn size(s: &Self) -> i64
}

impl Size for String {
  fn size(s: &Self) -> i64 {
    String::size s
  }
}

pub trait Indexable ['elem] {
  fn get(v: &Self, index: i64) -> 'elem
}

impl ['a] Indexable 'a for (Vector 'a) {
  fn get(v: &Self, index: i64) -> 'a {
    Vector::get (v, index)
  }
}
