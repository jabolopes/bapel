module;

#include <deque>
#include <variant>

import bapel.core;

export module bapel.stl:stl_deque;

// @bpl: pub type Deque ['a]
export {

template <typename A>
using Deque = std::deque<A>;

}  // namespace

// @bpl: pub deque::push_back: forall ['a] (&Deque 'a, 'a) -> ()
export namespace deque {

template <typename A>
std::monostate push_back(Deque<A>* deque, A a) {
	deque->push_back(std::move(a));
	return std::monostate();
}

}  // namespace deque
