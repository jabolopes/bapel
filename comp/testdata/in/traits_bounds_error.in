module traits_bounds_error

impls {
  "ptr.h"
}

type Ptr ['a]

trait Size {
  fn size(s: &Self) -> i64
}

type S = struct { x: i64 }

impl Size for S {
  fn size(s: &Self) -> i64 {
    (*s).x
  }
}

type Unrelated = struct { y: i64 }

fn printSize['t: Size](x: & 't) -> i64 {
  Size::size x
}

fn run() -> i64 {
  let u: Unrelated = struct { y = 42 };
  printSize [Unrelated] &u
}
