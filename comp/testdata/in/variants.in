module variants

type Choice ['a] = variant {left 'a, right i8}

fn mkLeft['a](value: 'a) -> Choice 'a {
  let v: Choice 'a = variant { (Choice 'a) left = value }

  let v1: 'a = v.left
  let v2: 'a = v.0

  let v3: 'a = match v {
    left l => l,
    right r => v1,
  }

  v <- variant {(Choice 'a) left = value}

  let r: Choice 'a = v
  r
}

fn mkRight['a](value: i8) -> Choice 'a {
  let v: Choice 'a = variant { (Choice 'a) right = value }

  let v1: i8 = v.right
  let v2: i8 = v.1

  let v3: i8 = match v {
    left l => v2,
    right r => r,
  }

  v <- variant {(Choice 'a) right = value}

  let r: Choice 'a = v
  r
}

/* Test variant with unit type in tags and exported types */

pub type Maybe ['a] = variant {none (), some 'a}

pub fn mkNone['a]() -> Maybe 'a {
  let v: Maybe 'a = variant { (Maybe 'a) none = () }

  let v1: () = v.none
  let v2: () = v.0

  let v3: () = match v {
    none l => l,
    some r => v1,
  }

  v <- variant {(Maybe 'a) none = ()}

  let r: Maybe 'a = v
  r
}

pub fn mkSome['a](value: 'a) -> Maybe 'a {
  let v: Maybe 'a = variant { (Maybe 'a) some = value }

  let v1: 'a = v.some
  let v2: 'a = v.1

  let v3: 'a = match v {
    none l => v2,
    some r => r,
  }

  v <- variant {(Maybe 'a) some = value}

  let r: Maybe 'a = v
  r
}
