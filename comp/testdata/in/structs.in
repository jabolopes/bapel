module structs

fn mkStruct1() -> struct{x i8, y i16} {
  struct {x = 1, y = 2}
}

fn mkStruct2() -> struct{x i8, y i16} {
  struct {x = 1 [i8], y = 2 [i16]}
}

fn mkStruct3() -> struct{x i8, y i16} {
  let r1: struct{x i8, y i16} = struct {x = 0, y = 0}
  let r2: struct{x i8, y i16} = struct {x = 0 [i8], y = 0 [i16]}

  let x: i8 = r1->x
  let y: i16 = r1->y

  set r1 {x = 3, y = 4}
  r1 <- set r1 {x = 3, y = 4}

  set r1 {0 = 3, 1 = 4}
  r1 <- set r1 {0 = 3, 1 = 4}

  let r: struct{x i8, y i16} = r1
  r
}

fn getStruct1(r: struct{x i8}) -> i8 {
  r->x
}

fn getStruct2(r: struct{x i8, y i16}) -> i16 {
  r->y
}

type Point = struct{x i8, y i16}

fn mkPoint1() -> Point {
  struct {x = 1, y = 2}
}

fn mkPoint2() -> Point {
  struct {x = 1 [i8], y = 2 [i16]}
}

fn mkPoint3() -> Point {
  let r1: Point = struct {x = 0, y = 0}
  let r2: Point = struct {x = 0 [i8], y = 0 [i16]}

  let x: i8 = r1->x
  let y: i16 = r1->y

  set r1 {x = 3, y = 4}
  r1 <- set r1 {x = 3, y = 4}

  set r1 {0 = 3, 1 = 4}
  r1 <- set r1 {0 = 3, 1 = 4}

  let r: Point = r1
  r
}

fn getPoint1(p: Point) -> i8 {
  p->x
}

fn getPoint2(p: Point) -> i16 {
  p->y
}
