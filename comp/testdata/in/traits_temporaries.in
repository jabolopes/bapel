module traits_temporaries

impls {
  "ptr.h"
}

type Ptr ['a]

trait Size {
  fn size(s: &Self) -> i64
}

type S = struct { x: i64 }

impl Size for S {
  fn size(s: &Self) -> i64 {
    (*s).x
  }
}

fn make_s(val: i64) -> S {
  struct { x = val }
}

fn printSize['t: Size](x: & 't) -> i64 {
  Size::size x
}

fn run() -> i64 {
  let a: i64 = printSize [S] &(make_s 10);
  let b: i64 = Size::size &(make_s 20);
  a + b
}
