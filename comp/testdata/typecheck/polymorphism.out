/* testdata/in/polymorphism.in:11-13 */fn callPolymorphic() -> () {
  ((core::print:(forall ['a] 'a -> ()) [i8]):(i8 -> ()) (1:(forall ['a] 'a) [i8]):i8):()
}:()

/* testdata/in/polymorphism.in:15-18 */fn functionSubtyping() -> () {
