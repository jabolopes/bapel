module;

#include <array>
#include <cstdlib>
#include <functional>
#include <optional>
#include <string>
#include <tuple>
#include <variant>
#include <vector>

export module lambda;

int8_t lambda();
export int8_t lambda2();
int8_t lambda() {
  std::function<int8_t(int8_t)> add = [](int8_t x) {
    return (x) + (static_cast<int8_t>(1));
  };
  return add(static_cast<int8_t>(2));
}

export int8_t lambda2() {
  std::function<int8_t(int8_t)> add = [](int8_t x) {
    return (x) + (static_cast<int8_t>(1));
  };
  return add(static_cast<int8_t>(2));
}
