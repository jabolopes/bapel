decls {
  /* polymorphism.comp.in:11-13 */callPolymorphic: () -> ()
  /* polymorphism.comp.in:15-18 */functionSubtyping: () -> ()
  /* polymorphism.comp.in:7-9 */id: forall ['a] 'a -> 'a
}

/* polymorphism.comp.in:7-9 */fn id['a ∗](x: 'a) -> 'a {
  x:'a
}:'a

/* polymorphism.comp.in:11-13 */fn callPolymorphic() -> () {
  ((core.print:(forall ['a] 'a -> ()) [i8]):(i8 -> ()) (1:(forall ['a] 'a) [i8]):i8):()
}:()

/* polymorphism.comp.in:15-18 */fn functionSubtyping() -> () {
  (let id2: i8 -> i8 = (id:(forall ['a] 'a -> 'a) [i8]):(i8 -> i8)):(i8 -> i8)
  ():()
}:()
