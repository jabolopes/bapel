type Choice ['a] = variant {left 'a, right i8}

fn mkLeft['a](value: 'a) -> (Choice 'a) {
  let v: Choice 'a = variant { (Choice 'a) left = value }

  let v1: 'a = v->left
  let v2: 'a = v->0

  let v3: 'a = case v {
    | left l = l
    | right r = v1
  }

  v <- variant {(Choice 'a) left = value}

  let r: Choice 'a = v
  r
}

fn mkRight['a](value: i8) -> (Choice 'a) {
  let v: Choice 'a = variant { (Choice 'a) right = value }

  let v1: i8 = v->right
  let v2: i8 = v->1

  let v3: i8 = case v {
    | left l = v2
    | right r = r
  }

  v <- variant {(Choice 'a) right = value}

  let r: Choice 'a = v
  r
}
