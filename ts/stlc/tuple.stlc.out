/* tuple.stlc.in: 12-24 */fn mkTuple3() -> (i8, i16) {
  (let r1: (i8, i16) = ((1:(forall ['a] 'a) [i8]):i8, (2:(forall ['a] 'a) [i16]):i16):(i8, i16)):(i8, i16)
  (let r2: (i8, i16) = ((1:(forall ['a] 'a) [i8]):i8, (2:(forall ['a] 'a) [i16]):i16):(i8, i16)):(i8, i16)
  (let x: i8 = (r1:(i8, i16)->0):i8):i8
  (let y: i16 = (r1:(i8, i16)->1):i16):i16
  set r1:(i8, i16) {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:(i8, i16)
  (r1:(i8, i16) <- set r1:(i8, i16) {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:(i8, i16)):(i8, i16)
  (let r: (i8, i16) = r1:(i8, i16)):(i8, i16)
  r1:(i8, i16)
}:(i8, i16)
