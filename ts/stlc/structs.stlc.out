  (let r2: struct{x i8, y i16} = struct{x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:struct{x i8, y i16}):struct{x i8, y i16}
  (let x: i8 = (r1:struct{x i8, y i16}.x):i8):i8
  (let y: i16 = (r1:struct{x i8, y i16}.y):i16):i16
  set r1:struct{x i8, y i16} {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:struct{x i8, y i16}
  (r1:struct{x i8, y i16} <- set r1:struct{x i8, y i16} {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:struct{x i8, y i16}):struct{x i8, y i16}
