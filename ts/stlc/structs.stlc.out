  (r1:struct{x i8, y i16} <- set r1:struct{x i8, y i16} {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:struct{x i8, y i16}):struct{x i8, y i16}
  (let r: struct{x i8, y i16} = r1:struct{x i8, y i16}):struct{x i8, y i16}
  r:struct{x i8, y i16}
}:struct{x i8, y i16}

