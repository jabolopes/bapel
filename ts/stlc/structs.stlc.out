/* structs.stlc.in:41-56 */fn mkPoint3() -> Point {
  (let r1: Point = struct{x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:struct{x i8, y i16}):Point
  (let r2: Point = struct{x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:struct{x i8, y i16}):Point
  (let x: i8 = r1:Point.x):i8
  (let y: i16 = r1:Point.y):i16
  set r1:Point {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:Point
  (r1:Point <- set r1:Point {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:Point):Point
  set r1:Point {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:Point
  (r1:Point <- set r1:Point {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:Point):Point
  (let r: Point = r1:Point):Point
  r:Point
}:Point

/* structs.stlc.in:58-62 */fn mkPolymorphicStruct() -> () {
  struct{x = 0:(forall ['a] 'a)}:(forall ['a] struct{x 'a})
  struct{x = 0:(forall ['a] 'a), y = 1:(forall ['a] 'a)}:(forall ['a, 'b] struct{x 'a, y 'b})
  ():()
}:()
