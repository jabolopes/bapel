type i8

fn callAdd() -> () {
  let i: i8 = 0
  let j: i8 = 0
  i + j
  ()
}

fn assignWithIDs() -> () {
  let x: i8 = 0
  let i: i8 = 0
  let j: i8 = 0
  x <- i + j
  ()
}

fn assignWithIDAndLiterals() -> () {
  let x: i8 = 0
  let i: i8 = 0
  x <- i + 1
  ()
}

fn assignWithLiterals() -> () {
  let x: i8 = 0
  x <- 1 + 2
  ()
}
