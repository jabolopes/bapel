/* inferencer_test7.in: 1 */type Point = {x i8, y i16}
/* inferencer_test7.in: 3-8 */fn mkPoint() -> () {
  (let r: Point = {x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  (let x: i8 = (r:{x i8, y i16}->x:i8):i8):i8
  (let y: i16 = (r:{x i8, y i16}->y:i16):i16):i16
  ():()
}:()
