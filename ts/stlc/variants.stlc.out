unit {
  module variants
  filename "variants.stlc.in"
  base
}

decls {
  /* variants.stlc.in:5 */type Choice :: ∗ -> ∗
  /* variants.stlc.in:43 */export type Maybe :: ∗ -> ∗
  /* variants.stlc.in:3 */type i8
  /* variants.stlc.in:43 */export type Maybe :: ∗ -> ∗ = fun (a ∗) (variant{none (), some 'a})
  /* variants.stlc.in:5 */type Choice :: ∗ -> ∗ = fun (a ∗) (variant{left 'a, right i8})
  /* variants.stlc.in:7-22 */mkLeft: forall ['a] 'a -> Choice 'a
  /* variants.stlc.in:45-60 */export mkNone: forall ['a] () -> Maybe 'a
  /* variants.stlc.in:24-39 */mkRight: forall ['a] i8 -> Choice 'a
  /* variants.stlc.in:62-77 */export mkSome: forall ['a] 'a -> Maybe 'a
}

/* variants.stlc.in:7-22 */fn mkLeft['a ∗](value: 'a) -> Choice 'a {
  (let v: Choice 'a = (variant{(Choice 'a) left = value:'a}):(Choice 'a)):(Choice 'a)
  (let v1: 'a = (v:(Choice 'a).left):'a):'a
  (let v2: 'a = (v:(Choice 'a).0):'a):'a
  (let v3: 'a = case v:(Choice 'a) {
    left l -> l
    right r -> v1}):'a
  (v:(Choice 'a) <- (variant{(Choice 'a) left = value:'a}):(Choice 'a)):(Choice 'a)
  (let r: Choice 'a = v:(Choice 'a)):(Choice 'a)
  r:(Choice 'a)
}:(Choice 'a)

/* variants.stlc.in:24-39 */fn mkRight['a ∗](value: i8) -> Choice 'a {
  (let v: Choice 'a = (variant{(Choice 'a) right = value:i8}):(Choice 'a)):(Choice 'a)
  (let v1: i8 = (v:(Choice 'a).right):i8):i8
  (let v2: i8 = (v:(Choice 'a).1):i8):i8
  (let v3: i8 = case v:(Choice 'a) {
    left l -> v2
    right r -> r}):i8
  (v:(Choice 'a) <- (variant{(Choice 'a) right = value:i8}):(Choice 'a)):(Choice 'a)
  (let r: Choice 'a = v:(Choice 'a)):(Choice 'a)
  r:(Choice 'a)
}:(Choice 'a)

/* variants.stlc.in:45-60 */export fn mkNone['a ∗]() -> Maybe 'a {
  (let v: Maybe 'a = (variant{(Maybe 'a) none = ():()}):(Maybe 'a)):(Maybe 'a)
  (let v1: () = (v:(Maybe 'a).none):()):()
  (let v2: () = (v:(Maybe 'a).0):()):()
  (let v3: () = case v:(Maybe 'a) {
    none l -> l
    some r -> v1}):()
  (v:(Maybe 'a) <- (variant{(Maybe 'a) none = ():()}):(Maybe 'a)):(Maybe 'a)
  (let r: Maybe 'a = v:(Maybe 'a)):(Maybe 'a)
  r:(Maybe 'a)
}:(Maybe 'a)

/* variants.stlc.in:62-77 */export fn mkSome['a ∗](value: 'a) -> Maybe 'a {
  (let v: Maybe 'a = (variant{(Maybe 'a) some = value:'a}):(Maybe 'a)):(Maybe 'a)
  (let v1: 'a = (v:(Maybe 'a).some):'a):'a
  (let v2: 'a = (v:(Maybe 'a).1):'a):'a
  (let v3: 'a = case v:(Maybe 'a) {
    none l -> v2
    some r -> r}):'a
  (v:(Maybe 'a) <- (variant{(Maybe 'a) some = value:'a}):(Maybe 'a)):(Maybe 'a)
  (let r: Maybe 'a = v:(Maybe 'a)):(Maybe 'a)
  r:(Maybe 'a)
}:(Maybe 'a)
