/* struct.stlc.in: 1 */type i8
/* struct.stlc.in: 2 */type i16
/* struct.stlc.in: 4-6 */fn mkStruct1() -> {x i8, y i16} {
  {x = (1:(forall ['a] 'a) [i8]):i8, y = (2:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
}:{x i8, y i16}
/* struct.stlc.in: 8-10 */fn mkStruct2() -> {x i8, y i16} {
  {x = (1:(forall ['a] 'a) [i8]):i8, y = (2:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
}:{x i8, y i16}
/* struct.stlc.in: 12-27 */fn mkStruct3() -> {x i8, y i16} {
  (let r1: {x i8, y i16} = {x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  (let r2: {x i8, y i16} = {x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  (let x: i8 = (r1:{x i8, y i16}->x):i8):i8
  (let y: i16 = (r1:{x i8, y i16}->y):i16):i16
  set r1:{x i8, y i16} {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
  (r1:{x i8, y i16} <- set r1:{x i8, y i16} {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  set r1:{x i8, y i16} {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
  (r1:{x i8, y i16} <- set r1:{x i8, y i16} {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  (let r: {x i8, y i16} = r1:{x i8, y i16}):{x i8, y i16}
  r:{x i8, y i16}
}:{x i8, y i16}
/* struct.stlc.in: 29 */type Point = {x i8, y i16}
/* struct.stlc.in: 31-33 */fn mkPoint1() -> Point {
  {x = (1:(forall ['a] 'a) [i8]):i8, y = (2:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
}:{x i8, y i16}
/* struct.stlc.in: 35-37 */fn mkPoint2() -> Point {
  {x = (1:(forall ['a] 'a) [i8]):i8, y = (2:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
}:{x i8, y i16}
/* struct.stlc.in: 39-54 */fn mkPoint3() -> Point {
  (let r1: Point = {x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  (let r2: Point = {x = (0:(forall ['a] 'a) [i8]):i8, y = (0:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  (let x: i8 = (r1:{x i8, y i16}->x):i8):i8
  (let y: i16 = (r1:{x i8, y i16}->y):i16):i16
  set r1:{x i8, y i16} {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
  (r1:{x i8, y i16} <- set r1:{x i8, y i16} {x = (3:(forall ['a] 'a) [i8]):i8, y = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  set r1:{x i8, y i16} {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
  (r1:{x i8, y i16} <- set r1:{x i8, y i16} {0 = (3:(forall ['a] 'a) [i8]):i8, 1 = (4:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}):{x i8, y i16}
  (let r: Point = r1:{x i8, y i16}):{x i8, y i16}
  r:{x i8, y i16}
}:{x i8, y i16}
