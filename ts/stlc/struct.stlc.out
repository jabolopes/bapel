/* struct.stlc.in: 4 */type i16
/* struct.stlc.in: 6-8 */fn mkStruct1() -> {x i8, y i16} {
  {x = (1:(forall ['a] 'a) [i8]):i8, y = (2:(forall ['a] 'a) [i16]):i16}:{x i8, y i16}
}:{x i8, y i16}
/* struct.stlc.in: 10-12 */fn mkStruct2() -> {x i8, y i16} {
