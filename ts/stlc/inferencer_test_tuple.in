fn mkTuple1() -> (i8, i16) {
  (1, 2)
}

fn mkTuple2() -> (i8, i16) {
  (1 [i8], 2 [i16])
}

fn mkTuple3() -> (i8, i16) {
  let r1: (i8, i16) = (1, 2)
  let r2: (i8, i16) = (1 [i8], 2 [i16])

  let x: i8 = r1->0
  let y: i8 = r1->1

  set r1 {0 = 3, 1 = 4}
  r1 <- set r1 {0 = 3, 1 = 4}

  let r: (i8, i16) = r1
  r1
}

type Point = (i8, i16)

fn mkPoint1() -> Point {
  (1, 2)
}

fn mkPoint2() -> Point {
  (1 [i8], 2 [i16])
}

fn mkPoint3() -> Point {
  let r1: Point = (1, 2)
  let r2: Point = (1 [i8], 2 [i16])

  let x: i8 = r1->0
  let y: i8 = r1->1

  set r1 {0 = 3, 1 = 4}
  r1 <- set r1 {0 = 3, 1 = 4}

  let r: Point = r1
  r1
}
