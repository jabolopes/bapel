/* inferencer_test_variant.in: 1-0 */type Choice = fun (a ∗) ({|left 'a, right i8|})
/* inferencer_test_variant.in: 3-21 */fn mkLeft['a ∗](value: 'a) -> Choice 'a {
  (let v: Choice 'a = ({|Choice 'a left = value:'a|}):{|left 'a, right i8|}):{|left 'a, right i8|}
  (let v1: 'a = (v:{|left 'a, right i8|}->left):'a):'a
  (let v2: 'a = (v:{|left 'a, right i8|}->0:(forall ['b] 'b)):'a):'a
  (let v3: 'a = (case v:{|left 'a, right i8|} of
  | left l -> l:'a
  | right r -> v1:'a):'a):'a
  (v:{|left 'a, right i8|} <- ({|Choice 'a left = value:'a|}):{|left 'a, right i8|}):{|left 'a, right i8|}
  Index.set v:{|left 'a, right i8|} left value:'a
  Index.set v:{|left 'a, right i8|} 0:(forall ['b] 'b) value:'a
  (let r: Choice 'a = v:{|left 'a, right i8|}):{|left 'a, right i8|}
  r:{|left 'a, right i8|}
}:{|left 'a, right i8|}
/* inferencer_test_variant.in: 23-41 */fn mkRight['a ∗](value: i8) -> Choice 'a {
  (let v: Choice 'a = ({|Choice 'a right = value:i8|}):{|left 'a, right i8|}):{|left 'a, right i8|}
  (let v1: i8 = (v:{|left 'a, right i8|}->right):i8):i8
  (let v2: i8 = (v:{|left 'a, right i8|}->1:(forall ['b] 'b)):i8):i8
  (let v3: i8 = (case v:{|left 'a, right i8|} of
  | left l -> v2:i8
  | right r -> r:i8):i8):i8
  (v:{|left 'a, right i8|} <- ({|Choice 'a right = value:i8|}):{|left 'a, right i8|}):{|left 'a, right i8|}
  Index.set v:{|left 'a, right i8|} right value:i8
  Index.set v:{|left 'a, right i8|} 1:(forall ['b] 'b) value:i8
  (let r: Choice 'a = v:{|left 'a, right i8|}):{|left 'a, right i8|}
  r:{|left 'a, right i8|}
}:{|left 'a, right i8|}
